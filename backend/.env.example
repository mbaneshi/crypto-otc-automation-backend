# Application
NODE_ENV=development
PORT=3000
APP_NAME=OTC Automation Backend

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=otc_platform
DATABASE_SSL=false
DATABASE_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_REFRESH_EXPIRATION=7d

# Binance P2P API
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_BASE_URL=https://testnet.binance.vision
BINANCE_WEBHOOK_SECRET=your_binance_webhook_secret

# NPP (New Payments Platform)
NPP_MERCHANT_ID=your_npp_merchant_id
NPP_API_KEY=your_npp_api_key
NPP_API_SECRET=your_npp_api_secret
NPP_BASE_URL=https://api.npp-provider.com
NPP_CALLBACK_URL=https://your-domain.com/webhooks/npp

# Sumsub KYC
SUMSUB_APP_TOKEN=your_sumsub_app_token
SUMSUB_SECRET_KEY=your_sumsub_secret_key
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_WEBHOOK_URL=https://your-domain.com/webhooks/sumsub
SUMSUB_WEBHOOK_SECRET=your_sumsub_webhook_secret

# Webhook Security
WEBHOOK_GLOBAL_SECRET=your_global_webhook_secret

# Encryption
ENCRYPTION_KEY=your_encryption_key_32_characters_long
ENCRYPTION_ALGORITHM=aes-256-gcm

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3002
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# Email (for alerts)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@otc-platform.com

# Monitoring
SENTRY_DSN=your_sentry_dsn

# Feature Flags
ENABLE_WEBSOCKETS=true
ENABLE_RECONCILIATION_JOB=true
ENABLE_ORDER_MONITORING_JOB=true

# Reconciliation Job Schedule
RECONCILIATION_CRON=0 0 * * *

# Order Monitoring Job Schedule
ORDER_MONITORING_CRON=*/5 * * * *
